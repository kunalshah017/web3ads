# Web3Ads OpenClaw Skill Configuration

# Required: Your wallet address with Web3Ads earnings
WEB3ADS_WALLET_ADDRESS=0xYourWalletAddress

# Optional: API endpoint (default: https://api.web3ads.wtf)
WEB3ADS_API_URL=https://api.web3ads.wtf

# Optional: Enable execution tools (campaign creation, payments)
WEB3ADS_ENABLE_EXECUTION=false

# Optional: Budget limits
WEB3ADS_MAX_USD_PER_CALL=1.00
WEB3ADS_MAX_USD_PER_DAY=10.00
