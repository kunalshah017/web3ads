{
  "name": "web3ads-mcp-server",
  "version": "1.0.0",
  "description": "Web3Ads MCP server for x402 agent payments using ad earnings",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "web3ads-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
