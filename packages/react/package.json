{
  "name": "@web3ads/react",
  "version": "0.1.0",
  "description": "Web3Ads React component for publishers to monetize their sites",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "web3",
    "advertising",
    "ads",
    "react",
    "monetization",
    "publisher",
    "crypto"
  ],
  "author": "web3ads",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunalshah017/web3ads"
  }
}
