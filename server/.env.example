# Copy to server/.env and fill in values
# Never commit .env to git

PORT=3001

# SQLite DB path (relative to server root)
DATABASE_URL=./web3ads.db

# ── Relayer wallet ──────────────────────────────────────────────────────────
# Generate a NEW throwaway wallet in MetaMask → Settings → export private key
# Fund it with 0.05 ETH on Base Sepolia: https://faucet.quicknode.com/base/sepolia
RELAYER_PRIVATE_KEY=0x

# ── Chain config ────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── Deployed contract addresses ─────────────────────────────────────────────
# Set these AFTER running: forge script script/Deploy.s.sol --broadcast (from gasless/)
FORWARDER_ADDRESS=
GREETING_BOX_ADDRESS=

# ── Credit config ───────────────────────────────────────────────────────────
# Gas units awarded per 30s ad watch
CREDITS_PER_WATCH=50000
