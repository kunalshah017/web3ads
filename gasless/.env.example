# Copy this to gasless/.env and fill in the values
# NEVER commit .env to git

# Your relayer/deployer wallet private key (generate a throwaway in MetaMask)
# This wallet MUST have Base Sepolia ETH to pay gas
PRIVATE_KEY=0x

# Base Sepolia RPC — free public endpoint
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Basescan API key — free from https://basescan.org/myapikey
BASESCAN_API_KEY=

# Set these AFTER deploying with: forge script script/Deploy.s.sol --broadcast
FORWARDER_ADDRESS=
GREETING_BOX_ADDRESS=
